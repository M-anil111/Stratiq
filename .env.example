# ============================================================================
# Stratiq — environment variables reference
# Copy to .env.local for development, and set the same keys in Vercel
# (Project → Settings → Environment Variables) for production.
# ============================================================================

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public base URL of the deployed app. Used to build OAuth redirect_uris,
# email links, and as a fallback when a request's own origin isn't reliable.
NEXT_PUBLIC_APP_URL=https://stratiqnow.com
NODE_ENV=production

# ---------------------------------------------------------------------------
# Supabase (database + auth) — required
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=
# Service-role key — bypasses RLS. Server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection strings (used by scripts/migrations, not the app runtime).
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
SUPABASE_DB_URL=

# ---------------------------------------------------------------------------
# Security — required
# ---------------------------------------------------------------------------
# AES-256-GCM key used to encrypt stored credentials (login_credentials,
# social_media_accounts passwords). Losing this key makes existing encrypted
# data unrecoverable — back it up somewhere safe outside the repo.
ENCRYPTION_KEY=
NEXTAUTH_SECRET=
# Shared secret Vercel Cron sends to authenticate calls to app/api/cron/*.
CRON_SECRET=
# Used by the client-impersonation / "log in as" support flow, if enabled.
IMPERSONATION_SECRET=

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Stratiq <noreply@stratiqnow.com>"
# Fallback recipient for admin notifications when no org notification_emails
# setting is configured yet.
APPROVAL_EMAIL=jay@jaymehta.co

# ---------------------------------------------------------------------------
# Google (OAuth login, Drive storage, Ads, Places, service account)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Service account JSON (as a single-line string) for server-side Drive/Ads access.
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_PARENT_FOLDER_ID=
GOOGLE_PLACES_API_KEY=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_MCC_ID=

# ---------------------------------------------------------------------------
# Meta (Facebook/Instagram Ads + social publishing)
# ---------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_AD_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# QuickBooks
# ---------------------------------------------------------------------------
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# 'true' to use the sandbox API host, unset/'false' for production QuickBooks.
QUICKBOOKS_SANDBOX=false

# ---------------------------------------------------------------------------
# ProofHub (task management integration)
# ---------------------------------------------------------------------------
PROOFHUB_ACCOUNT_URL=
PROOFHUB_API_KEY=

# ---------------------------------------------------------------------------
# Helcim (invoice payments)
# ---------------------------------------------------------------------------
HELCIM_API_TOKEN=
HELCIM_PAYMENT_PAGE_URL=
HELCIM_WEBHOOK_VERIFIER_TOKEN=

# ---------------------------------------------------------------------------
# AI (Claude, for report captions/summaries)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Sentry (error monitoring)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=mindshare-consulting-inc
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Cloudflare
# ---------------------------------------------------------------------------
# Turnstile (bot protection on login/request-access forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Web Analytics beacon token (only needed if using Manual Setup instead of
# Cloudflare's Automatic Setup, which requires no code/env var at all)
NEXT_PUBLIC_CF_BEACON_TOKEN=
